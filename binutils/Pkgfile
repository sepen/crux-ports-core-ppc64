# Description: The GNU Binutils are a collection of binary tools
# URL: https://www.gnu.org/software/binutils/
# Maintainer: CRUX System Team, core-ports at crux dot nu
# Arch Maintainer: Jose Beneyto, sepen at crux dot nu
# Depends on: zlib flex

name=binutils
version=2.43.1
release=1
source=(https://ftpmirror.gnu.org/gnu/$name/$name-$version.tar.xz)

build() {
    mkdir build
    cd build

    ../$name-$version/configure --prefix=/usr \
	--build=powerpc64-unknown-linux-gnu \
        --enable-shared \
        --enable-64-bit-bfd \
        --enable-default-execstack=no \
        --enable-ld=default \
        --enable-lto \
        --enable-pgo-build=lto \
        --enable-gold=yes \
        --enable-plugins \
        --enable-install-libiberty \
        --with-bugurl=https://github.com/sepen/crux-ports-core-ppc64/issues \
        --with-pic \
        --with-system-zlib \
        --without-stage1-ldflags \
        --disable-jansson \
        --disable-nls \
        --disable-werror

    sed -i -e '/^MAKEINFO/s:=.*:= true:' Makefile

    make tooldir=/usr
    make tooldir=/usr DESTDIR=$PKG install

    rm -r $PKG/usr/share/info
    sed -i "s|-L$SRC[^ ]* ||g" $PKG/usr/lib/lib{bfd,ctf,ctf-nobfd,opcodes}.la
}
